endif

SRCS += $(EXTRA_SRCS)
OBJS = $(SRCS:.c=.o)
CC  = $(CROSS_COMPILE)gcc
CFLAGS += -Wall -Wextra -O2 -std=gnu99

ifneq ($(TARGET), pc)
    ifneq ($(SYSROOT),)
        CFLAGS  += --sysroot=$(SYSROOT)
        LDFLAGS += --sysroot=$(SYSROOT)
    endif
endif

all: $(EXE)

